# TaskPilot AI Agent - Environment Variables
# Copy this file to .env and fill in your values

# LLM API Configuration (DeepSeek via OpenAI-compatible API)
# Leave OPENAI_API_KEY empty to use rule-based mock LLM
OPENAI_API_KEY=sk-your-deepseek-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# Agent settings
MAX_ITERATIONS=10
AGENT_PORT=8001
